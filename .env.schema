# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

SLACK_CLIENT_ID=your-slack-client-id
# @sensitive
SLACK_CLIENT_SECRET=your-slack-client-secret
# @sensitive
SLACK_SIGNING_SECRET=your-signing-secret
# @sensitive
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
# @type=url
TURSO_DATABASE_URL=libsql://your-database.turso.io
# @sensitive
TURSO_AUTH_TOKEN=your-turso-auth-token
# @type=port
PORT=3000
# @type=url
PUBLIC_BASE_URL=https://gossiper.company/api
# Optional override if different from PUBLIC_BASE_URL + /slack/oauth/callback
# SLACK_REDIRECT_URI=https://gossiper.company/api/slack/oauth/callback
# Gossip mode: comma-separated channel IDs to operate in (replaces SLACK_CHANNEL_ID)
# SLACK_CHANNEL_WHITELIST=C0123456789,C9876543210
# How long (ms) before gossiping about the same sender again (default: 300000 = 5 min)
# GOSSIP_COOLDOWN_MS=300000
# Probability (0-1) of gossiping on any given message (default: 0.6)
# GOSSIP_PROBABILITY=0.6

# items added to schema by `varlock init`
# that were missing in example, but detected in other .env files
# PLEASE REVIEW THESE!
# ---
# @type=number
GOSSIP_PROBABILITY=0.6
