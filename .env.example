SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-signing-secret
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example
# Optional override if different from PUBLIC_BASE_URL + /slack/oauth/callback
# SLACK_REDIRECT_URI=https://your-domain.example/slack/oauth/callback
# Optional: limit the bot to one channel in every workspace
# SLACK_CHANNEL_ID=C0123456789
# Gossip mode: comma-separated channel IDs to operate in (replaces SLACK_CHANNEL_ID)
# SLACK_CHANNEL_WHITELIST=C0123456789,C9876543210
# Comma-separated user IDs to send gossip messages to
# SLACK_USER_WHITELIST=U0123456789,U9876543210
# How long (ms) before gossiping about the same sender again (default: 300000 = 5 min)
# GOSSIP_COOLDOWN_MS=300000
# Probability (0-1) of gossiping on any given message (default: 0.6)
# GOSSIP_PROBABILITY=0.6
